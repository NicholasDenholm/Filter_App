<?xml version="1.0" encoding="utf-8"?>
<!-- Root: ScrollView so the image can never overlap controls below it -->
<ScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#12121A"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <!-- ── Top bar ─────────────────────────────────────────── -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Filter Studio"
            android:textColor="#F0F0F0"
            android:textSize="20sp"
            android:textStyle="bold"
            android:layout_marginBottom="12dp" />

        <!-- ── Image preview (capped height so it never overflows) -->
        <ImageView
            android:id="@+id/image_view"
            android:layout_width="match_parent"
            android:layout_height="260dp"
            android:adjustViewBounds="false"
            android:scaleType="centerCrop"
            android:src="@drawable/test_image"
            android:background="#1E1E2A"
            android:contentDescription="@string/my_image_description"
            android:layout_marginBottom="16dp" />

        <!-- ── Filter selector card ────────────────────────────── -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardBackgroundColor="#1E1E2A"
            app:cardCornerRadius="10dp"
            app:cardElevation="0dp"
            android:layout_marginBottom="12dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="12dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="FILTER"
                    android:textColor="#666666"
                    android:textSize="11sp"
                    android:letterSpacing="0.1"
                    android:layout_marginBottom="8dp" />

                <!-- Spinner styled to match dark theme via spinnerStyle in themes.xml -->
                <Spinner
                    android:id="@+id/filter_spinner"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="@drawable/spinner_bg"
                    android:paddingStart="10dp"
                    android:paddingEnd="10dp"
                    android:paddingTop="8dp"
                    android:paddingBottom="8dp"
                    android:popupBackground="#1E1E2A" />

            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- ── Seekbar card ────────────────────────────────────── -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardBackgroundColor="#1E1E2A"
            app:cardCornerRadius="10dp"
            app:cardElevation="0dp"
            android:layout_marginBottom="16dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="12dp">

                <!-- Header row: label on left, live value on right -->
                <RelativeLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="8dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="CLUSTERS / BLOCK SIZE"
                        android:textColor="#666666"
                        android:textSize="11sp"
                        android:letterSpacing="0.1"
                        android:layout_centerVertical="true" />

                    <!-- This TextView is updated in Java as the seekbar moves -->
                    <TextView
                        android:id="@+id/seek_value_label"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="10"
                        android:textColor="#AFA9EC"
                        android:textSize="22sp"
                        android:textStyle="bold"
                        android:layout_alignParentEnd="true" />

                </RelativeLayout>

                <!-- SeekBar: min=2, max=22, default=10 -->
                <SeekBar
                    android:id="@+id/seekBar2"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:min="2"
                    android:max="22"
                    android:progress="10"
                    android:progressTint="#7F77DD"
                    android:thumbTint="#7F77DD"
                    android:progressBackgroundTint="#2A2A38"
                    android:layout_marginBottom="6dp" />

                <!-- Tick labels below the seekbar -->
                <RelativeLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="2"
                        android:textColor="#444444"
                        android:textSize="10sp"
                        android:layout_alignParentStart="true" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="8"
                        android:textColor="#444444"
                        android:textSize="10sp"
                        android:layout_centerHorizontal="true"
                        android:layout_marginStart="-30dp" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="14"
                        android:textColor="#444444"
                        android:textSize="10sp"
                        android:layout_centerHorizontal="true"
                        android:layout_marginStart="30dp" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="22"
                        android:textColor="#444444"
                        android:textSize="10sp"
                        android:layout_alignParentEnd="true" />

                </RelativeLayout>

            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- ── Button row ──────────────────────────────────────── -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center"
            android:layout_marginBottom="16dp">

            <!-- Camera button: outlined secondary style -->
            <Button
                android:id="@+id/button_photo"
                android:layout_width="0dp"
                android:layout_height="48dp"
                android:layout_weight="1"
                android:text="Camera"
                android:textColor="#BBBBBB"
                android:backgroundTint="#1E1E2A"
                android:layout_marginEnd="8dp"
                style="@style/Widget.MaterialComponents.Button.OutlinedButton" />

            <!-- Apply button: filled primary style -->
            <Button
                android:id="@+id/button_process"
                android:layout_width="0dp"
                android:layout_height="48dp"
                android:layout_weight="2"
                android:text="Apply Filter"
                android:textColor="#FFFFFF"
                android:backgroundTint="#534AB7"
                style="@style/Widget.MaterialComponents.Button" />

        </LinearLayout>

        <!-- ── Progress bar (hidden until processing) ─────────── -->
        <ProgressBar
            android:id="@+id/progressBar"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center_horizontal"
            android:indeterminateTint="#7F77DD"
            android:visibility="gone" />

    </LinearLayout>
</ScrollView>